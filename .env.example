# claud.i Configuration
# Copy to .env and fill in values

# ── Required ──
TELEGRAM_BOT_TOKEN=

# ── Recommended ──
# Comma-separated Telegram user IDs (security allowlist)
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=

# ── Identity (optional) ──
# BOT_NAME=Jarvis
# BOT_EMOJI=🦾
# BOT_USER_NAME=형님
# BOT_LANGUAGE=ko

# ── Paths (optional) ──
# CLAUDE_PATH=claude
# SESSIONS_DIR=./data
# SKILLS_DIR=./skills
# AGENTS_DIR=./agents

# ── Sessions (optional) ──
# SESSION_IDLE_TIMEOUT=30
# MAX_SESSIONS=5

# ── Webhook server (optional) ──
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=3000
