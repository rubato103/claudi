# claud.i Configuration
# Copy to .env and fill in values

# Required: Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Recommended: Comma-separated Telegram user IDs (security)
TELEGRAM_ALLOWED_USERS=

# Optional: Claude CLI path (default: "claude")
# CLAUDE_PATH=claude

# Optional: Data directory (default: ./data)
# SESSIONS_DIR=./data

# Optional: Idle timeout in minutes (default: 30)
# SESSION_IDLE_TIMEOUT=30

# Optional: Max concurrent sessions (default: 5)
# MAX_SESSIONS=5

# Optional: Webhook server (default: enabled on port 3000)
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=3000

# Optional: Skills directory (default: ./skills)
# SKILLS_DIR=./skills
