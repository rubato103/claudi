# claud.i Configuration
# Copy this file to .env and fill in the values

# Required: Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Recommended: Comma-separated Telegram user IDs for access control
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=

# Optional: Path to claude CLI (default: "claude")
# CLAUDE_PATH=claude

# Optional: Data directory for session persistence (default: ./data)
# SESSIONS_DIR=./data

# Optional: Idle session timeout in minutes (default: 30)
# SESSION_IDLE_TIMEOUT=30

# Optional: Maximum concurrent Claude sessions (default: 5)
# MAX_SESSIONS=5
